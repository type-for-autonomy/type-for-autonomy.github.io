---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro"

export async function getStaticPaths() {
  const teamMembers = await getCollection('team');
  return teamMembers.map(member => ({
    params: { slug: member.slug  },
    props: { member }
  }));
}

const { member } = Astro.props;
const { Content } = await member.render();
const hasText = (value?: string) => Boolean(value?.trim());

const links = member.data.links ?? {};
for (let item in links) {
  console.log(`Link key: ${item}, value: ${links[item]}`); // Debugging log to check each link key and value
}


---

<Layout title={`${member.data.name} - TYPE Team`}>
  <main class="team-member" id="main-content">
    <section class="team-member__section section-inner">
      <a href="/team" class="team-member__back">← Back to Team</a>
      
      <div class="team-member__header">
        <img 
          src={member.data.image} 
          alt={member.data.name}
          class="team-member__image"
        />
        <div class="team-member__header-info">
          <h1>{member.data.name}</h1>
          <p class="team-member__role">{member.data.role}</p> 
          {Object.keys(links).length > 0 && (
            <div class="team-member__connect" aria-label="Member contact and social links">
              {Object.entries(links).map(item => 
                <a
                  href={item[1]}
                  class="team-member__connect-link"
                  target={ "_blank"}
                >
                  {item[0].replace(/[-_]/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
                </a>
              )}
            </div>
          )}
        </div>
      </div>

      <div class="team-member__description">
        {member.data.description && (
          <p class="team-member__intro">{member.data.description}</p>
        )}
      </div>

      <div class="team-member__content">
        <Content />
      </div>
    </section>
  </main>
</Layout>

<style>
  .team-member {
    min-height: 100svh;
    background: var(--color-bg);
    color: var(--color-text);
    padding: clamp(1.5rem, 3vw, 2.5rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .team-member__section {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 46rem;
  }

  .team-member__back {
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    padding: 0;
  }

  .team-member__back:hover,
  .team-member__back:focus-visible {
    color: var(--color-accent);
    outline: none;
  }

  .team-member__header {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1.15rem;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 0.0625rem solid color-mix(in srgb, var(--color-text-muted) 25%, transparent);
  }

  .team-member__image {
    width: 100%;
    height: 10rem;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 999px;
  }

  .team-member__header-info {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .team-member__header-info h1 {
    font-size: clamp(2rem, 3.6vw, 2.6rem);
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
  }

  .team-member__role {
    font-size: 1.06rem;
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0;
    margin: 0;
  }

  .team-member__email-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.92rem;
    word-break: break-all;
  }

  .team-member__email-link:hover,
  .team-member__email-link:focus-visible {
    color: var(--color-accent);
    outline: none;
  }

  .team-member__email-link--muted {
    margin: 0;
    color: var(--color-text-muted);
  }

  .team-member__connect {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.2rem;
  }

  .team-member__connect-link {
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.28rem 0.62rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-primary) 18%, transparent);
    transition: background var(--transition), color var(--transition);
  }

  .team-member__connect-link:hover,
  .team-member__connect-link:focus-visible {
    color: var(--color-bg);
    background: var(--color-primary);
    outline: none;
  }

  .team-member__description {
    padding: 0;
  }

  .team-member__intro {
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--color-text);
    margin: 0;
  }

  .team-member__content {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
    padding: 0;
  }

  .team-member__content :global(h2) {
    font-size: 1.35rem;
    color: var(--color-text);
    font-weight: 700;
    letter-spacing: 0;
    margin: 0.4rem 0 0.35rem;
  }

  .team-member__content :global(h2:first-child) {
    margin-top: 0;
  }

  .team-member__content :global(p) {
    font-size: 1.08rem;
    line-height: 1.85;
    color: var(--color-text);
    margin: 0;
  }

  .team-member__content :global(ul) {
    list-style: disc;
    padding-left: 1.2rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .team-member__content :global(li) {
    color: var(--color-text);
    line-height: 1.7;
  }

  /* Tablet: 48rem (768px) */
  @media (max-width: 48rem) {
    
    .team-member {
      padding: clamp(1.5rem, 4vw, 2.5rem) 0;
      
    }

    .team-member__header {
      grid-template-columns: 7rem 1fr;
      gap: 0.85rem;
      justify-self: center;
      text-align: center;
    }

    .team-member__section {
      gap: 1.5rem;
    }

    .team-member__header-info h1 {
      font-size: 1.8rem;
    }

    .team-member__image {
      height: 7rem;
    }
  }

  /* Mobile: 28rem (448px) */
  @media (max-width: 28rem) {
    
    .team-member {
      padding: 1.5rem 0;
    }

    .team-member__back {
      font-size: 0.9rem;
    }

    .team-member__header-info h1 {
      font-size: 1.5rem;
    }

    .team-member__header {
      grid-template-columns: 1fr;
      justify-items: center;
    }

    .team-member__image {
      width: 8rem;
      height: 8rem;
    }

    .team-member__role {
      font-size: 0.95rem;
    }

    .team-member__email-link {
      font-size: 0.9rem;
    }

    .team-member__intro {
      font-size: 1rem;
    }

  .team-member__connect{
    justify-content: center;  
  }

    .team-member__content :global(h2) {
      font-size: 1.2rem;
    }

    .team-member__content :global(p) {
      font-size: 1rem;
    }
  }
</style>
