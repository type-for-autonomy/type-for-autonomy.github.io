--- 
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro"

const teamMembers = await getCollection('team');
// Sort alphabetically by name for consistent display
const sortedTeam = teamMembers.sort((a, b) => a.data.name.localeCompare(b.data.name));
const hasText = (value?: string) => Boolean(value?.trim());
const primaryRole = (role: string) => {
  const cleanedRole = role.trim();
  if (/professor/i.test(cleanedRole)) return "Professor";
  if (/phd\s*student/i.test(cleanedRole)) return "PhD Student";
  if (/graduate\s*researcher/i.test(cleanedRole)) return "Graduate Researcher";
  return cleanedRole.split(/\s*(?:&|,|\/)\s*/)[0].trim();
};
---

<Layout>
  <main class="team" id="main-content">
    <section class="team__section section-inner">
      <div class="team__intro">
        <h1>Our Team</h1>
        <p>Meet the passionate individuals behind TYPE.</p>
      </div>
      <div class="team__core">
        <h2>Core Team</h2>
        <ul class="team__list" role="list">
          {sortedTeam.map((member) => (
            <li class="team__card">
              <a href={`/team/${member.slug}`} class="team__card-link">
                <div class="team__visual">
                  <img 
                    src={member.data.image} 
                    alt={member.data.name}
                    class="team__image"
                    loading="lazy"
                  />
                </div>
                <div class="team__info">
                  <h3>{member.data.name}</h3>
                  <p class="team__role">{primaryRole(member.data.role)}</p>
                {hasText(member.data.email) ? (
                  <p class="team__email">
                    {member.data.email}
                  </p>
                ) : (
                  <p class="team__email team__email--muted">Email not listed</p>
                )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- <div class="team__codesign">
        <h2>Co-Design Team</h2>
        <p class="team__codesign-intro">Our co-design team includes nonspeaking autistic individuals, caregivers, educators, and community partners who guide and inform our work.</p>
        <div class="team__placeholder">
          <p>Co-design team member profiles coming soon</p>
        </div>
      </div> -->
    </section>
  </main>
</Layout>

<style>
  .team {
    min-height: 100svh;
    background: var(--color-bg);
    color: var(--color-text);
    padding: clamp(2rem, 5vw, 4rem) 0;
  }

  .team__section {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 5rem);
  }

  .team__intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-self: center; 
    text-align: center  ;
  }

  .team__intro h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .team__intro p {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-text-muted);
    max-width: 50rem;
  }

  /* Core Team */
  .team__core {
    display: flex;
    flex-direction: column;
    /* gap: 2rem; */
  }

  .team__core h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .team__list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .team__card {
    background: var(--color-surface);
    border: none;
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
  }

  .team__card:hover,
  .team__card:focus-within {
    transform: translateY(-0.25rem);
    box-shadow: 0 0.35rem 1.25rem rgba(0, 0, 0, 0.08);
  }

  .team__card-link {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
  }

  .team__card-link:focus-visible {
    outline: 0.1875rem solid var(--color-accent);
    outline-offset: -0.1875rem;
  }

  .team__visual {
    position: relative;
    min-height: 15rem;
    padding-top: 1rem;
    background: var(--color-bg);
    overflow: hidden;
  }

  .team__visual::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0; 
    top: 46%;
    bottom: 0;
    background: var(--color-primary);
  }

  .team__image {
    position: relative;
    z-index: 1;
    display: block;
    width: min(100%, 13.5rem);
    margin-inline: auto;
    aspect-ratio: 4 / 5;
    object-fit: contain;
    object-position: center bottom;
    padding: 0;
    background: transparent;
    transition: transform var(--transition);
  }

  .team__card:hover .team__image,
  .team__card:focus-within .team__image {
    transform: scale(1.08);
  }

  .team__info {
    padding: 1.5rem 1.25rem 1.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex-grow: 1;
    text-align: center;
  }

  .team__info h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .team__role {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 500;
    margin: 0;
  }

  .team__email {
    font-size: 0.86rem;
    color: var(--color-primary);
    margin: 0;
    word-break: break-all;
  }

  .team__email--muted {
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Co-Design Section */
  .team__codesign {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: clamp(2rem, 4vw, 3rem);
    background: var(--color-surface);
    border: 0.25rem solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .team__codesign h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .team__codesign-intro {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 45rem;
  }

  .team__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    background: rgba(224, 211, 19, 0.05);
    border: 0.125rem dashed var(--color-primary);
    border-radius: var(--radius-md);
    padding: 2rem;
  }

  .team__placeholder p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    font-style: italic;
    text-align: center;
  }

  /* Tablet: 48rem (768px) */
  @media (max-width: 48rem) {
    .team {
      padding: clamp(1.5rem, 4vw, 2.5rem) 0;
    }

    .team__section {
      gap: clamp(2rem, 4vw, 3rem);
    }

    .team__intro h1 {
      font-size: clamp(2rem, 4vw, 3rem);
    }

    .team__intro p {
      font-size: 1rem;
    }

    .team__list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .team__visual {
      min-height: 14rem;
    }

    .team__image {
      width: min(100%, 12.5rem);
    }

    .team__info {
      padding: 1.5rem;
    }

    .team__codesign {
      padding: 1.5rem;
    }
  }

  /* Mobile: 28rem (448px) */
  @media (max-width: 28rem) {
    .team {
      padding: 1.5rem 0;
    }

    .team__intro h1 {
      font-size: 1.75rem;
    }

    .team__intro p {
      font-size: 0.95rem;
    }

    .team__list {
      gap: 1rem;
    }

    .team__visual {
      min-height: 12.5rem;
    }

    .team__image {
      width: min(100%, 11.25rem);
    }

    .team__card:hover,
    .team__card:focus-within {
      transform: none;
    }

    .team__info {
      padding: 1rem;
    }

    .team__info h3 {
      font-size: 1.1rem;
    }

    .team__role {
      font-size: 0.85rem;
    }
  }
</style>
