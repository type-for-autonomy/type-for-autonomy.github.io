---
// GetInvolved.astro
---
<section id="journey" class="journey  global-height" aria-labelledby="journey-heading">
  <div class="journey__inner section-inner">
    <div>
      <h2 id="journey-heading">Our Journey</h2>
      <p class="journey__sub">Where we are now, and where we are going</p>
    </div>
    <img src="/assets/TYPE/Part 5/image page 5.png" alt="Journey from info hub to prototype to evaluation" loading="lazy" />
    <a href="#footer-involved" class="btn">Get Updates</a>
  </div>
</section>

<style>  
.journey {
    display: flex;
    align-items: center;
    background: var(--color-bg);
  }

  .journey__inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(2.5rem, 10vh, 4rem);
    padding: 0 clamp(1.25rem, 4vw, 2.25rem);
  }
  .journey h2 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    text-align: center;
  }

  .journey__sub {
    color: var(--color-primary);
    font-size: clamp(1.1rem, 1.8vw, 1.6rem);
    font-weight: 600;
    margin: 0;
    text-align: center;
  }

  .journey img {
    width: clamp(30rem, 70vw, 55rem);
    height: auto;
    object-fit: contain;
  }

  /* Tablet: 48rem (768px) */
  @media (max-width: 48rem) {
    .journey {
      height: auto;
      min-height: 100vh;
      padding-block: clamp(2rem, 4vh, 3rem);
    }

    .journey__inner {
      gap: clamp(1.5rem, 3vh, 2rem);
      padding: 1rem clamp(0.75rem, 2vw, 1rem);
    }

    .journey h2 {
      font-size: clamp(2.5rem, 8vw, 4rem);
    }

    .journey__sub {
      font-size: clamp(1rem, 3vw, 1.6rem);
    }

    .journey img {
      width: clamp(40rem, 85vw, 60vw);
    }

    /* .journey .btn {
      margin-top: clamp(1rem, 2vh, 1.5rem);
    } */
  }

  /* Mobile: 28rem (448px) */
  @media (max-width: 28rem) {
    .journey {
      min-height: auto;
      padding-block: 1.5rem;
    }

    .journey__inner {
      gap: 1rem;
      padding: 0.75rem 0.5rem;
    }

    .journey h2 {
      font-size: clamp(1.8rem, 6vw, 3rem);
      letter-spacing: -0.01em;
    }

    .journey__sub {
      font-size: clamp(0.9rem, 2.5vw, 1.2rem);
    }

    .journey img {
      width: clamp(15rem, 90vw, 25rem);
    }

    /* .journey .btn {
      font-size: 0.75rem;
      padding: 0.45rem 1.2rem;
      min-height: 2.4rem;
      margin-top: 1rem;
    } */
  }
</style>
