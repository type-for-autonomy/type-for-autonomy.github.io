---
// About.astro
---
<section id="mission" class="mission global-height" aria-labelledby="mission-heading">
    <div class="mission__inner section-inner">
      <div class="mission__inner__left">
        <h2 id="mission-heading">Your voice.<br />Your way.</h2>
        <a href="#process" class="mission__inner__btn btn">Our Mission</a>
      </div>
      <div class="mission__inner__right">
        <img src="/assets/TYPE/Part 2/infinity.png" alt="" aria-hidden="true" loading="lazy" />
        <p class="mission__inner__description">
          We are building TYPE to create innovative, adaptive training for nonspeaking autistic
          people to grow their skills and be heard.
        </p>
      </div>
  </div>
</section>

<style>  
.mission {
    display: flex;
    align-items: center;
    background: var(--color-surface-alt);
    color: #0d0d0d;
    
  }

  .mission__inner {
         display: flex;
    flex: 1;
    flex-direction: row;
    align-items: center;
    justify-content: space-around;
    gap: clamp(2rem, 3vw, 3.5rem);
    width: 100%;
  }

  .mission__inner__left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    gap: clamp(3rem, 10vw, 4rem);
  }

  .mission__inner__right {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
  }
  .mission__inner__right  img {
    width: clamp(20rem, 35vw, 30rem);
    height: auto;
    object-fit: contain;
  }
  .mission__inner__left h2 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 500;
    line-height: 0.95;
    margin: 0;
  }

  .mission__inner__description {
    color: #222;
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    line-height: 1.45;
    max-width: 50rem;
    margin: 0;
  }

  .mission__inner__btn {
    width: fit-content;
    color: #ffffff;
    border-color: #000;
    background: #000;
  }

  .mission__panel .btn:hover,
  .mission__panel .btn:focus-visible {
    background: #1d1d1d;
    color: #fff;
  }
  /* Tablet: 48rem (768px) */
  @media (max-width: 48rem) {
    .mission {
      padding-block: clamp(2rem, 4vh, 3rem);
    }

    .mission__inner {
      flex-direction: column-reverse;
      gap: clamp(2rem, 4vh, 2.5rem);
    }

    .mission__inner__left {
      align-items: center;
      gap: clamp(2rem, 3vh, 2.5rem);
    }

    .mission__inner__left h2 {
      font-size: clamp(2.5rem, 8vw, 4rem);
      text-align: center;
    }

    .mission__inner__right {
      align-items: center;
    }

    .mission__inner__right img {
      width: clamp(15rem, 50vw, 25rem);
    }

    .mission__inner__description {
      font-size: clamp(1rem, 2.5vw, 1.5rem);
      text-align: center;
      max-width: 100%;
    }
  }

  /* Mobile: 28rem (448px) */
  @media (max-width: 28rem) {
    .mission {
      padding-block: 1.5rem;
    }

    .mission__inner {
      gap: 1.5rem;
    }

    .mission__inner__left {
      gap: 1.5rem;
    }

    .mission__inner__left h2 {
      font-size: clamp(2rem, 7vw, 3rem);
      text-align: center;
    }

    .mission__inner__right {
      gap: 1rem;
    }

    .mission__inner__right img {
      width: clamp(12rem, 60vw, 20rem);
    }

    .mission__inner__description {
      font-size: clamp(0.95rem, 2vw, 1.2rem);
      text-align: center;
    }
  }

</style>
