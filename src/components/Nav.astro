---
// Nav.astro
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isTeam = pathname === '/team' || pathname.startsWith('/team/');
const isBlog = pathname === '/blog' || pathname.startsWith('/blog/');
---
<header class:list={['header', 'nav-height']} role="banner">
  <nav class="nav section-inner" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="TYPE — home">
      <img class="logo-mark" src="/assets/TYPE/Part 1/Logo Image.png" alt="" aria-hidden="true" />
      <span class="logo-text">TYPE</span>
    </a>

    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-controls="nav-links"
      aria-expanded="false"
      aria-label="Open navigation menu"
    >
      <span class="burger" aria-hidden="true"></span>
      <span class="burger" aria-hidden="true"></span>
      <span class="burger" aria-hidden="true"></span>
    </button>

    <ul class="nav-links" id="nav-links" role="list">
      <li><a href="/" class:list={['page-link', {active: isHome}]}>Home</a></li>
      <!-- <li><a href="#mission" class="section-link">Mission</a></li>
      <li><a href="#values" class="section-link">Values</a></li>
      <li><a href="#process" class="section-link">Process</a></li>
      <li><a href="#journey" class="section-link">Journey</a></li>
      <li><a href="#partners" class="section-link">Partners</a></li> -->
      <li><a href="/team" class:list={['page-link', {active: isTeam}]}>Team</a></li>
      <li><a href="/blog" class:list={['page-link', {active: isBlog}]}>Updates</a></li>
      <li>
        <a href="#footer-involved" class="nav-cta">Get Involved</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.header');
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const links = document.getElementById('nav-links') as HTMLUListElement | null;

  if (!header || !toggle || !links) {
    throw new Error('Nav elements are missing from the page.');
  }

  const headerEl = header;
  const toggleBtn = toggle;
  const linksEl = links;

  // Configuration
  const TOP_REVEAL_ZONE_PX = 120;
  const SCROLL_SHOW_PX = 24;
  const SCROLL_HIDE_DELAY_MS = 2000; // Hide navbar after 2 seconds of no scrolling
  const MOBILE_MEDIA_QUERY = '(max-width: 45em)';

  const allTabs = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.nav-links a:not(.nav-cta)'),
  );
  const pageTabs = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.nav-links a.page-link'),
  );
  const sectionTabs = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.nav-links a.section-link[href^="#"]'),
  );

  let pointerNearTop = false;
  let isScrolling = false;
  let scrollHideTimeout: number | null = null;
  let lastScrollTime = 0;

  function setActiveTab(tab: HTMLAnchorElement | null): void {
    allTabs.forEach((item) => item.classList.remove('active'));
    if (tab) tab.classList.add('active');
  }

  function clearScrollHideTimeout(): void {
    if (scrollHideTimeout !== null) {
      clearTimeout(scrollHideTimeout);
      scrollHideTimeout = null;
    }
  }

  function updateHeaderVisibility(): void {
    if (window.matchMedia(MOBILE_MEDIA_QUERY).matches) {
      headerEl.classList.add('is-visible');
      return;
    }

    const menuOpen = linksEl.classList.contains('open');
    const shouldShow = isScrolling || pointerNearTop || menuOpen || window.scrollY > SCROLL_SHOW_PX;
    headerEl.classList.toggle('is-visible', shouldShow);
  }

  function closeMobileMenu(): void {
    toggleBtn.setAttribute('aria-expanded', 'false');
    linksEl.classList.remove('open');
    updateHeaderVisibility();
  }

  // Toggle mobile menu
  toggleBtn.addEventListener('click', () => {
    const isOpen = toggleBtn.getAttribute('aria-expanded') === 'true';
    toggleBtn.setAttribute('aria-expanded', String(!isOpen));
    linksEl.classList.toggle('open', !isOpen);
    updateHeaderVisibility();
  });

  // Close mobile menu after any link click
  linksEl.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Handle scroll with auto-hide delay
  window.addEventListener('scroll', () => {
    lastScrollTime = Date.now();
    isScrolling = true;
    updateHeaderVisibility();

    clearScrollHideTimeout();

    // Hide navbar after delay of no scrolling
    scrollHideTimeout = window.setTimeout(() => {
      isScrolling = false;
      updateHeaderVisibility();
    }, SCROLL_HIDE_DELAY_MS);
  }, { passive: true });

  window.addEventListener('resize', updateHeaderVisibility);

  // Show nav while hovering near top edge
  window.addEventListener('mousemove', (event) => {
    pointerNearTop = event.clientY <= TOP_REVEAL_ZONE_PX;
    updateHeaderVisibility();
  });

  // Keyboard users should also be able to reveal it
  document.addEventListener('focusin', () => {
    pointerNearTop = true;
    updateHeaderVisibility();
  });

  // Build section list only for sections that exist on current page
  const sectionEntries: Array<{ tab: HTMLAnchorElement; section: HTMLElement }> = [];
  for (const tab of sectionTabs) {
    const id = tab.getAttribute('href')?.slice(1);
    if (!id) continue;
    const section = document.getElementById(id);
    if (!section) continue;
    sectionEntries.push({ tab, section });
  }

  if (sectionEntries.length > 0) {
    // On section-based pages, section highlight has priority over page-level tabs
    setActiveTab(null);

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const match = sectionEntries.find((item) => item.section === entry.target);
          if (!match) continue;
          setActiveTab(match.tab);
        }
      },
      { rootMargin: '-35% 0px -55% 0px', threshold: 0.01 },
    );

    sectionEntries.forEach((item) => observer.observe(item.section));
  } else {
    // On non-section pages, keep one page tab active
    const activePageTab = pageTabs.find((item) => item.classList.contains('active')) ?? null;
    setActiveTab(activePageTab);
  }

  updateHeaderVisibility();

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    clearScrollHideTimeout();
  });
</script>

<style>  .header {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(5, 5, 5, 0.95);
    backdrop-filter: blur(0.5rem);
    border-bottom: 0.0625rem solid var(--color-border);
    transform: translateY(-110%);
    opacity: 0;
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1), opacity 300ms ease-out;
    will-change: transform, opacity;
  }

  .header.is-visible {
    transform: translateY(0);
    opacity: 1;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
    gap: 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
  }
  .logo-mark {
    display: block;
    width: 2.25rem;
    height: 2.25rem;
    object-fit: contain;
    flex-shrink: 0;
  }
  .logo-text {
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 0.08em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    flex-wrap: wrap;
  }
  .nav-links a {
    display: block;
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: background var(--transition), color var(--transition);
  }
  .nav-links a:hover {
    background: var(--color-tag-bg);
    color: var(--color-primary);
  }

  .nav-links a.active {
    background: var(--color-primary);
    color: #000;
    font-weight: 700;
  }
  .nav-cta {
    /* background: var(--color-primary) !important; */
    color: #000 !important;
    border-radius: var(--radius-sm);
    font-weight: 600 !important;
  }
  .nav-cta:hover {
    background: var(--color-primary-dk) !important;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 0.3125rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
  }
  .burger {
    display: block;
    width: 1.5rem;
    height: 0.125rem;
    background: var(--color-text);
    border-radius: 0.125rem;
    transition: transform var(--transition);
  }

  @media (max-width: 45em) {
    .header {
      transform: translateY(0);
      opacity: 1;
    }

    .menu-toggle { display: flex; }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--color-surface);
      border-bottom: 0.0625rem solid var(--color-border);
      padding: 1rem var(--space-md);
      gap: 0.25rem;
    }
    .nav-links.open { display: flex; }
    .nav-links a { font-size: 1rem; padding: 0.6rem 0.75rem; }
  }
</style>
